{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noEmit": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["main", "shared", "vite.config.ts", "vitest.config.ts"],
  "composite": true
}
